# SuperNova Tools — Environment Variables
# Copy this file to .env.local and fill in values

# Phase 2: Google Sheets Integration
# Base64-encoded service account JSON for Google Sheets API access
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet ID containing FB Ads data (from Make.com sync)
FB_ADS_SHEET_ID=

# Phase 3: AI Analysis (existing key, shared with tournament calculator)
ANTHROPIC_API_KEY=
